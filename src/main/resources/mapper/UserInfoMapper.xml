<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.xs.chat.mapper.UserInfoMapper">
    <insert id="insertUserInfo">
        INSERT INTO users
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="nickname != null">nickname,</if>
            <if test="passwordHash != null">password_hash,</if>
            <if test="email != null">email,</if>
            <if test="avatar != null">avatar,</if>
            <if test="status != null">status,</if>
            <if test="description != null">description,</if>
            <if test="onlineStatus != null">online_status,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
            <if test="lastLoginAt != null">last_login_at,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="nickname != null">#{nickname},</if>
            <if test="passwordHash != null">#{passwordHash},</if>
            <if test="email != null">#{email},</if>
            <if test="avatar != null">#{avatar},</if>
            <if test="status != null">#{status},</if>
            <if test="description != null">#{description},</if>
            <if test="onlineStatus != null">#{onlineStatus},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
            <if test="lastLoginAt != null">#{lastLoginAt},</if>
        </trim>
    </insert>


    <update id="updateUserInfo">
        UPDATE users
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            <if test="onlineStatus != null">online_status = #{onlineStatus},</if>
            <if test="lastLoginAt != null">last_login_at = #{lastLoginAt},</if>
            updated_at = now()
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectByEmail" resultType="com.xs.chat.pojo.DO.UserDO">
        SELECT * FROM users WHERE email = #{email} limit 1;
    </select>
    <select id="selectByNickname" resultType="com.xs.chat.pojo.DO.UserDO">
        SELECT * FROM users WHERE nickname = #{nickname} limit 1;
    </select>
    <select id="selectById" resultType="com.xs.chat.pojo.DO.UserDO">
        SELECT * FROM users WHERE id = #{id} limit 1;
    </select>
    <select id="selectBatchIds" resultType="com.xs.chat.pojo.DO.UserDO">
        SELECT * FROM users WHERE id IN
        <foreach item="item" collection="list" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>
</mapper>